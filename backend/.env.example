# TradeJini CubePlus API Credentials
# Get these from TradeJini CubePlus developer portal
TRADEJINI_API_KEY=your_api_key_here
TRADEJINI_API_SECRET=your_api_secret_here
TRADEJINI_CLIENT_ID=your_client_id_here
TRADEJINI_TOTP_SECRET=your_totp_secret_here
TRADEJINI_REDIRECT_URI=https://your-elastic-ip/api/tradejini/callback

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Portal Authentication
AUTH_EMAIL=your_email@example.com
AUTH_JWT_SECRET=your_random_secret_here
